# CashFromChaos environment

# --- Operator brain selection ---
# fixture = deterministic decisions for reliable demo/video (default)
# hermes  = live operator via the local `hermes` CLI. Policy-bound: decisions
#           and prices stay deterministic; Hermes writes the listing copy and
#           buyer replies, and falls back to fixture text on any failure.
# llm     = alias for hermes.
OPERATOR_BRAIN=fixture

# --- Stripe (test mode) ---
# Leave blank to run in SIMULATED payment mode (no network, fully demoable).
# Provide a test-mode secret key (sk_test_...) to use real Stripe Checkout.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Public base URL used for Stripe redirect URLs.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Hermes CLI operator (only used when OPERATOR_BRAIN=hermes|llm) ---
# The app shells out to a Hermes profile in single-shot mode (`<bin> -z ...`).
# DEFAULT BIN = `hackathon` (the isolated profile wrapper), NOT `hermes` — bare
# `hermes` would bill the user's personal `default` profile (OpenAI Codex /
# ChatGPT Plus) and exhaust their personal quota. Configure the hackathon
# profile once with: `hackathon portal` then `hackathon model` (Nemotron).
HERMES_BIN=hackathon
# HERMES_MODEL=...               # leave unset to use the profile's default model
# HERMES_TIMEOUT_MS=60000        # per-call timeout before falling back
